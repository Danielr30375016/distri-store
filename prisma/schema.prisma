// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id       Int     @id @default(autoincrement())
  name     String
  price    Int
  image    String?
  desc     String
  category String
}
